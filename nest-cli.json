{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/foodservers/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/foodservers/tsconfig.app.json"
  },
  "projects": {
    "cors": {
      "type": "library",
      "root": "libs/cors",
      "entryFile": "index",
      "sourceRoot": "libs/cors/src",
      "compilerOptions": {
        "tsConfigPath": "libs/cors/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "foodservers": {
      "type": "application",
      "root": "apps/foodservers",
      "entryFile": "main",
      "sourceRoot": "apps/foodservers/src",
      "compilerOptions": {
        "tsConfigPath": "apps/foodservers/tsconfig.app.json"
      }
    },
    "graphql": {
      "type": "library",
      "root": "libs/graphql",
      "entryFile": "index",
      "sourceRoot": "libs/graphql/src",
      "compilerOptions": {
        "tsConfigPath": "libs/graphql/tsconfig.lib.json"
      }
    },
    "payments": {
      "type": "application",
      "root": "apps/payments",
      "entryFile": "main",
      "sourceRoot": "apps/payments/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payments/tsconfig.app.json"
      }
    },
    "redis": {
      "type": "library",
      "root": "libs/redis",
      "entryFile": "index",
      "sourceRoot": "libs/redis/src",
      "compilerOptions": {
        "tsConfigPath": "libs/redis/tsconfig.lib.json"
      }
    }
  },
  "monorepo": true,
  "root": "apps/foodservers"
}